<Application x:Class="VirtualControllerEmulator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:VirtualControllerEmulator.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global converter instances -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
            <conv:ControllerTypeToStringConverter x:Key="ControllerTypeConverter"/>
            <conv:NullToVisibilityConverter x:Key="NullToVis"/>
            <conv:NullToVisibilityConverter x:Key="NullToVisInvert"/>
            <conv:ControllerTypeEqualityConverter x:Key="ControllerTypeToXbox"/>
            <conv:ControllerTypeEqualityConverter x:Key="ControllerTypeToDS4"/>
            <conv:NavigationPageToVisibilityConverter x:Key="PageToDashboard"/>
            <conv:NavigationPageToVisibilityConverter x:Key="PageToMapping"/>
            <conv:NavigationPageToVisibilityConverter x:Key="PageToProfiles"/>
            <conv:NavigationPageToVisibilityConverter x:Key="PageToSettings"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
