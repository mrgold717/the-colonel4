<UserControl x:Class="VirtualControllerEmulator.Views.ProfileManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Profile Manager" Style="{StaticResource TextHeading}"/>
            <TextBlock Text="Manage controller profiles. Each profile stores key mappings and controller settings."
                       Style="{StaticResource TextLabel}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main content: list + details -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Profile list -->
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource BrushAccent}"
                            Padding="12,8">
                        <TextBlock Text="Profiles" Style="{StaticResource TextSubHeading}"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Profiles}"
                             SelectedItem="{Binding SelectedProfile}"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding ControllerType,
                                                   Converter={StaticResource ControllerTypeConverter}}"
                                                   Style="{StaticResource TextLabel}" FontSize="10"/>
                                        <TextBlock Text=" ● Default"
                                                   Style="{StaticResource TextLabel}" FontSize="10"
                                                   Foreground="{StaticResource BrushHighlight}"
                                                   Visibility="{Binding IsDefault, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Profile details -->
            <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="Profile Details" Style="{StaticResource TextSubHeading}" Margin="0,0,0,12"/>

                        <!-- No selection state -->
                        <TextBlock Text="Select a profile from the list to view details."
                                   Style="{StaticResource TextSecondary}"
                                   Visibility="{Binding SelectedProfile, Converter={StaticResource NullToVis}}"/>

                        <!-- Details -->
                        <StackPanel Visibility="{Binding SelectedProfile, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:"
                                           Style="{StaticResource TextLabel}" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="0" Grid.Column="1"
                                         Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Controller:"
                                           Style="{StaticResource TextLabel}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <RadioButton Content="Xbox 360"
                                                 IsChecked="{Binding SelectedProfile.ControllerType,
                                                             Converter={StaticResource ControllerTypeToXbox}, ConverterParameter=Xbox360}"
                                                 Margin="0,0,16,0"/>
                                    <RadioButton Content="DualShock 4"
                                                 IsChecked="{Binding SelectedProfile.ControllerType,
                                                             Converter={StaticResource ControllerTypeToDS4}, ConverterParameter=DualShock4}"/>
                                </StackPanel>

                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Process:"
                                           Style="{StaticResource TextLabel}" VerticalAlignment="Center"
                                           ToolTip="Auto-activate when this process is in the foreground"/>
                                <TextBox Grid.Row="4" Grid.Column="1"
                                         Text="{Binding SelectedProfile.LinkedProcess, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="e.g. notepad, game.exe"/>

                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Default:"
                                           Style="{StaticResource TextLabel}" VerticalAlignment="Center"/>
                                <CheckBox Grid.Row="6" Grid.Column="1"
                                          IsChecked="{Binding SelectedProfile.IsDefault}"
                                          Content="Set as default profile"/>
                            </Grid>

                            <Separator/>

                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Button Content="⚡ Activate"
                                        Command="{Binding SetActiveProfileCommand}"
                                        Style="{StaticResource ButtonSuccess}"
                                        Margin="0,0,8,0"/>
                                <Button Content="⧉ Duplicate"
                                        Command="{Binding DuplicateProfileCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Content="↑ Export"
                                        Command="{Binding ExportProfileCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Content="🗑 Delete"
                                        Command="{Binding DeleteProfileCommand}"
                                        Style="{StaticResource ButtonDanger}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom toolbar -->
        <Border Grid.Row="2" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="↓ Import" Command="{Binding ImportProfileCommand}" Margin="0,0,8,0"/>
                    <Button Content="+ New Profile" Command="{Binding CreateProfileCommand}"
                            Style="{StaticResource ButtonSuccess}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
