<UserControl x:Class="VirtualControllerEmulator.Views.ControllerVisualizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="VisualizerRoot"
             Background="{StaticResource BrushBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,24">

            <!-- Header -->
            <TextBlock Text="Controller Visualizer" Style="{StaticResource TextHeading}" Margin="0,0,0,4"/>
            <TextBlock Text="Real-time view of controller state. Buttons light up when pressed."
                       Style="{StaticResource TextLabel}" Margin="0,0,0,16"/>

            <!-- Controller body -->
            <Border Style="{StaticResource CardBorder}" MaxWidth="640" HorizontalAlignment="Left">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top row: LB, LT, RT, RB -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" x:Name="BtnLB" CornerRadius="4" Padding="8,4"
                                Background="{StaticResource BrushAccent}" Margin="2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="LB" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <Border Grid.Column="1" x:Name="BtnLT" CornerRadius="4" Padding="8,4"
                                Background="{StaticResource BrushAccent}" Margin="2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="LT" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <Border Grid.Column="2" x:Name="BtnRT" CornerRadius="4" Padding="8,4"
                                Background="{StaticResource BrushAccent}" Margin="2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="RT" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <Border Grid.Column="3" x:Name="BtnRB" CornerRadius="4" Padding="8,4"
                                Background="{StaticResource BrushAccent}" Margin="2"
                                HorizontalAlignment="Center">
                            <TextBlock Text="RB" FontWeight="Bold" FontSize="11"/>
                        </Border>
                    </Grid>

                    <!-- Middle row: Left Stick + DPad | Center buttons | Right Stick + ABXY -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left side: Left Stick + DPad -->
                        <StackPanel Grid.Column="0">
                            <!-- Left stick visualizer -->
                            <TextBlock Text="Left Stick" Style="{StaticResource TextLabel}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Canvas x:Name="LeftStickCanvas" Width="80" Height="80"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource BrushAccent}"
                                    ClipToBounds="True">
                                <Ellipse Width="80" Height="80"
                                         Fill="Transparent"
                                         Stroke="{StaticResource BrushBorder}"
                                         StrokeThickness="2"
                                         Canvas.Left="0" Canvas.Top="0"/>
                                <Ellipse x:Name="LeftStickDot" Width="16" Height="16"
                                         Fill="{StaticResource BrushHighlight}"
                                         Canvas.Left="32" Canvas.Top="32"/>
                            </Canvas>

                            <!-- DPad -->
                            <TextBlock Text="D-Pad" Style="{StaticResource TextLabel}"
                                       HorizontalAlignment="Center" Margin="0,12,0,4"/>
                            <Grid Width="72" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="BtnDUp" Grid.Row="0" Grid.Column="1"
                                        Background="{StaticResource BrushAccent}" Margin="1" CornerRadius="2">
                                    <TextBlock Text="▲" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="BtnDLeft" Grid.Row="1" Grid.Column="0"
                                        Background="{StaticResource BrushAccent}" Margin="1" CornerRadius="2">
                                    <TextBlock Text="◄" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="BtnDRight" Grid.Row="1" Grid.Column="2"
                                        Background="{StaticResource BrushAccent}" Margin="1" CornerRadius="2">
                                    <TextBlock Text="►" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="BtnDDown" Grid.Row="2" Grid.Column="1"
                                        Background="{StaticResource BrushAccent}" Margin="1" CornerRadius="2">
                                    <TextBlock Text="▼" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Center: Back/Start/Guide -->
                        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border x:Name="BtnBack" CornerRadius="12" Width="36" Height="20"
                                    Background="{StaticResource BrushAccent}" Margin="0,4"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="Back" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="BtnGuide" CornerRadius="20" Width="32" Height="32"
                                    Background="{StaticResource BrushAccent}" Margin="0,4"
                                    HorizontalAlignment="Center"
                                    BorderBrush="{StaticResource BrushHighlight}" BorderThickness="2">
                                <TextBlock Text="⊙" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Foreground="{StaticResource BrushHighlight}"/>
                            </Border>
                            <Border x:Name="BtnStart" CornerRadius="12" Width="36" Height="20"
                                    Background="{StaticResource BrushAccent}" Margin="0,4"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="Start" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>

                        <!-- Right side: Right Stick + ABXY -->
                        <StackPanel Grid.Column="2">
                            <!-- ABXY -->
                            <TextBlock Text="Buttons" Style="{StaticResource TextLabel}"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <Grid Width="72" HorizontalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                    <RowDefinition Height="24"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="24"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="BtnY" Grid.Row="0" Grid.Column="1"
                                        Background="#336600" Margin="1" CornerRadius="12">
                                    <TextBlock Text="Y" FontSize="10" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#66FF00"/>
                                </Border>
                                <Border x:Name="BtnX" Grid.Row="1" Grid.Column="0"
                                        Background="#003366" Margin="1" CornerRadius="12">
                                    <TextBlock Text="X" FontSize="10" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#0099FF"/>
                                </Border>
                                <Border x:Name="BtnB" Grid.Row="1" Grid.Column="2"
                                        Background="#661A00" Margin="1" CornerRadius="12">
                                    <TextBlock Text="B" FontSize="10" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#FF4400"/>
                                </Border>
                                <Border x:Name="BtnA" Grid.Row="2" Grid.Column="1"
                                        Background="#006633" Margin="1" CornerRadius="12">
                                    <TextBlock Text="A" FontSize="10" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Foreground="#00FF88"/>
                                </Border>
                            </Grid>

                            <!-- Right stick visualizer -->
                            <TextBlock Text="Right Stick" Style="{StaticResource TextLabel}"
                                       HorizontalAlignment="Center" Margin="0,12,0,4"/>
                            <Canvas x:Name="RightStickCanvas" Width="80" Height="80"
                                    HorizontalAlignment="Center"
                                    Background="{StaticResource BrushAccent}"
                                    ClipToBounds="True">
                                <Ellipse Width="80" Height="80"
                                         Fill="Transparent"
                                         Stroke="{StaticResource BrushBorder}"
                                         StrokeThickness="2"
                                         Canvas.Left="0" Canvas.Top="0"/>
                                <Ellipse x:Name="RightStickDot" Width="16" Height="16"
                                         Fill="{StaticResource BrushHighlight}"
                                         Canvas.Left="32" Canvas.Top="32"/>
                            </Canvas>
                        </StackPanel>
                    </Grid>

                    <!-- Trigger indicators -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Left Trigger" Style="{StaticResource TextLabel}" HorizontalAlignment="Center"/>
                            <ProgressBar x:Name="LeftTriggerBar" Height="8" Margin="0,4,0,0"
                                         Minimum="0" Maximum="255" Value="0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                            <TextBlock Text="Right Trigger" Style="{StaticResource TextLabel}" HorizontalAlignment="Center"/>
                            <ProgressBar x:Name="RightTriggerBar" Height="8" Margin="0,4,0,0"
                                         Minimum="0" Maximum="255" Value="0"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
