<UserControl x:Class="VirtualControllerEmulator.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBackground}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="600" HorizontalAlignment="Left">

            <!-- Header -->
            <TextBlock Text="Settings" Style="{StaticResource TextHeading}" Margin="0,0,0,4"/>
            <TextBlock Text="Configure controller type, sensitivity, and application behavior."
                       Style="{StaticResource TextLabel}" Margin="0,0,0,20"/>

            <!-- Controller Type -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Controller Type" Style="{StaticResource TextSubHeading}" Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="Xbox 360" Margin="0,0,24,0"
                                     IsChecked="{Binding ActiveControllerType,
                                                 Converter={StaticResource ControllerTypeToXbox}}"/>
                        <RadioButton Content="DualShock 4"
                                     IsChecked="{Binding ActiveControllerType,
                                                 Converter={StaticResource ControllerTypeToDS4}}"/>
                    </StackPanel>
                    <TextBlock Text="Changing the controller type will reconnect the virtual controller."
                               Style="{StaticResource TextLabel}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Mouse Sensitivity -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Mouse Sensitivity" Style="{StaticResource TextSubHeading}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Sensitivity:" VerticalAlignment="Center"
                                   Style="{StaticResource TextLabel}"/>
                        <Slider Grid.Column="1" x:Name="SensitivitySlider"
                                Minimum="0.1" Maximum="5.0" Value="1.5"
                                TickFrequency="0.1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ElementName=SensitivitySlider, Path=Value, StringFormat='{}{0:F1}'}"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Style="{StaticResource TextLabel}"/>
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Mouse Target:" VerticalAlignment="Center"
                                   Style="{StaticResource TextLabel}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <RadioButton Content="Right Stick" Margin="0,0,16,0" IsChecked="True"
                                         GroupName="MouseTarget"/>
                            <RadioButton Content="Left Stick" GroupName="MouseTarget"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <CheckBox Content="Invert X Axis" Margin="0,0,24,0"/>
                        <CheckBox Content="Invert Y Axis"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Dead Zones -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Dead Zones" Style="{StaticResource TextSubHeading}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Left Stick:" VerticalAlignment="Center"
                                   Style="{StaticResource TextLabel}"/>
                        <Slider Grid.Column="1" x:Name="LeftDeadZoneSlider"
                                Minimum="0" Maximum="0.5" Value="0.1"
                                TickFrequency="0.01" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ElementName=LeftDeadZoneSlider, Path=Value, StringFormat='{}{0:P0}'}"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Style="{StaticResource TextLabel}"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Right Stick:" VerticalAlignment="Center"
                                   Style="{StaticResource TextLabel}"/>
                        <Slider Grid.Column="1" x:Name="RightDeadZoneSlider"
                                Minimum="0" Maximum="0.5" Value="0.1"
                                TickFrequency="0.01" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ElementName=RightDeadZoneSlider, Path=Value, StringFormat='{}{0:P0}'}"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Style="{StaticResource TextLabel}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Turbo Settings -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Turbo / Rapid Fire" Style="{StaticResource TextSubHeading}" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Default Rate:" VerticalAlignment="Center"
                                   Style="{StaticResource TextLabel}"/>
                        <Slider Grid.Column="1" x:Name="TurboRateSlider"
                                Minimum="5" Maximum="30" Value="10"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   VerticalAlignment="Center" Margin="4,0,0,0"
                                   Style="{StaticResource TextLabel}">
                            <Run Text="{Binding ElementName=TurboRateSlider, Path=Value, StringFormat='{}{0:F0}'}"/>
                            <Run Text=" Hz"/>
                        </TextBlock>
                    </Grid>
                    <TextBlock Text="Turbo can be enabled per-button in the Mapping Editor."
                               Style="{StaticResource TextLabel}"/>
                </StackPanel>
            </Border>

            <!-- Application Settings -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Application" Style="{StaticResource TextSubHeading}" Margin="0,0,0,12"/>
                    <CheckBox Content="Start with Windows" Margin="0,0,0,8"
                              x:Name="StartWithWindowsCheck"/>
                    <CheckBox Content="Start minimized to system tray" Margin="0,0,0,8"
                              x:Name="StartMinimizedCheck"/>
                    <CheckBox Content="Minimize to tray instead of taskbar" Margin="0,0,0,8"
                              x:Name="MinimizeToTrayCheck" IsChecked="True"/>
                    <CheckBox Content="Auto-connect on startup"
                              x:Name="AutoConnectCheck"/>
                    <Separator Margin="0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Apply Settings" Style="{StaticResource ButtonSuccess}"
                                Click="ApplySettings_Click" Margin="0,0,8,0"/>
                        <Button Content="Reset All Settings" Style="{StaticResource ButtonDanger}"
                                Click="ResetSettings_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
