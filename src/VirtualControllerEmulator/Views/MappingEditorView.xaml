<UserControl x:Class="VirtualControllerEmulator.Views.MappingEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:VirtualControllerEmulator.ViewModels"
             Background="{StaticResource BrushBackground}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="0,0,0,16">
            <StackPanel>
                <TextBlock Text="Key Mapping Editor" Style="{StaticResource TextHeading}"/>
                <TextBlock Text="Click a button row to remap it. Press the desired key or mouse button."
                           Style="{StaticResource TextLabel}" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Capture status -->
        <Border Grid.Row="1" Margin="0,0,0,12"
                Background="{StaticResource BrushHighlight}"
                CornerRadius="4" Padding="12,8"
                Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="White" FontWeight="SemiBold"/>
                <Button Grid.Column="1" Content="Cancel"
                        Command="{Binding CancelCapturingCommand}"
                        Background="#660020" Foreground="White"
                        Padding="10,4" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Mappings table -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Mappings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource BrushBorder}"
                                    BorderThickness="0,0,0,1">
                                <Grid Margin="12,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Controller Button Name -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding ButtonName}"
                                               Foreground="{StaticResource BrushTextSecondary}"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                    <!-- Mapped Key -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding MappedKey}"
                                               VerticalAlignment="Center"
                                               Margin="8,0"/>

                                    <!-- Turbo Toggle -->
                                    <CheckBox Grid.Column="2"
                                              IsChecked="{Binding TurboEnabled}"
                                              Content="Turbo"
                                              VerticalAlignment="Center"
                                              Margin="8,0"/>

                                    <!-- Remap button -->
                                    <Button Grid.Column="3"
                                            Content="Remap"
                                            Command="{Binding DataContext.StartCapturingCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding ButtonName}"
                                            Padding="10,4" Margin="4,0"/>

                                    <!-- Clear button -->
                                    <Button Grid.Column="4"
                                            Content="✕"
                                            Command="{Binding DataContext.ClearMappingCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding ButtonName}"
                                            Style="{StaticResource ButtonDanger}"
                                            Padding="8,4" Margin="4,0"
                                            ToolTip="Clear this mapping"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource BrushSuccess}"
                       VerticalAlignment="Center" Margin="0,0,16,0"
                       Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
            <Button Content="Reset to Default"
                    Command="{Binding ResetToDefaultCommand}"
                    Style="{StaticResource ButtonDanger}"
                    Margin="0,0,8,0"/>
            <Button Content="Save Mappings"
                    Command="{Binding SaveMappingsCommand}"
                    Style="{StaticResource ButtonSuccess}"/>
        </StackPanel>
    </Grid>
</UserControl>
