<Window x:Class="VirtualControllerEmulator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VirtualControllerEmulator.ViewModels"
        xmlns:views="clr-namespace:VirtualControllerEmulator.Views"
        xmlns:conv="clr-namespace:VirtualControllerEmulator.Converters"
        Title="Virtual Controller Emulator"
        Width="900" Height="620"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource MainWindowStyle}"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInvert" />
        <conv:ControllerTypeToStringConverter x:Key="ControllerTypeConverter"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisInvert"/>
        <conv:ControllerTypeEqualityConverter x:Key="ControllerTypeToXbox"/>
        <conv:ControllerTypeEqualityConverter x:Key="ControllerTypeToDS4"/>
        <conv:NavigationPageToVisibilityConverter x:Key="PageToDashboard"/>
        <conv:NavigationPageToVisibilityConverter x:Key="PageToMapping"/>
        <conv:NavigationPageToVisibilityConverter x:Key="PageToProfiles"/>
        <conv:NavigationPageToVisibilityConverter x:Key="PageToSettings"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <!-- Title bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="28"/>
            <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ==================== Title Bar ==================== -->
        <Border Grid.Row="0" Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App icon + name -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="24" Height="24" CornerRadius="4"
                            Background="{StaticResource BrushHighlight}" Margin="0,0,10,0">
                        <TextBlock Text="🎮" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Virtual Controller Emulator"
                               Foreground="{StaticResource BrushTextPrimary}"
                               FontFamily="Segoe UI Semibold" FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Connection status badge -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border CornerRadius="10" Padding="10,3" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#666680"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BrushSuccess}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontSize="11" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="● DISCONNECTED"/>
                                    <Setter Property="Foreground" Value="#AAAACC"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="● CONNECTED"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Window controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="—" Width="36" Height="28" Click="MinimizeButton_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource BrushTextSecondary}"
                            FontSize="16" Padding="0"/>
                    <Button Content="✕" Width="36" Height="28" Click="CloseButton_Click"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource BrushTextSecondary}"
                            FontSize="14" Padding="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ButtonBase}">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource BrushHighlight}"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== Main Content ==================== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" MinWidth="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ====== Left Sidebar ====== -->
            <Border Grid.Column="0"
                    Background="{StaticResource BrushSurface}"
                    BorderBrush="{StaticResource BrushBorder}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Navigation -->
                    <StackPanel Grid.Row="0" Margin="0,8,0,0">
                        <!-- Dashboard -->
                        <Button Content="📊  Dashboard"
                                Command="{Binding NavigateToDashboardCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Dashboard">
                                            <Setter Property="Style" Value="{StaticResource NavButtonActive}"/>
                                            <Setter Property="Foreground" Value="{StaticResource BrushHighlight}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Mapping -->
                        <Button Content="🎯  Mapping"
                                Command="{Binding NavigateToMappingCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Mapping">
                                            <Setter Property="Foreground" Value="{StaticResource BrushHighlight}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Profiles -->
                        <Button Content="📁  Profiles"
                                Command="{Binding NavigateToProfilesCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Profiles">
                                            <Setter Property="Foreground" Value="{StaticResource BrushHighlight}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Settings -->
                        <Button Content="⚙️  Settings"
                                Command="{Binding NavigateToSettingsCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentPage}" Value="Settings">
                                            <Setter Property="Foreground" Value="{StaticResource BrushHighlight}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Separator Margin="8,8"/>

                        <!-- Connect/Disconnect button -->
                        <Button Margin="8,4"
                                Command="{Binding ConnectCommand}"
                                Style="{StaticResource ButtonSuccess}"
                                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisInvert}, ConverterParameter=Invert}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="▶  Connect" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="8,4"
                                Command="{Binding DisconnectCommand}"
                                Style="{StaticResource ButtonDanger}"
                                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⏹  Disconnect" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Profile info at bottom -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BrushAccent}"
                            Padding="12,8"
                            Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Active Profile" Style="{StaticResource TextLabel}" FontSize="10"/>
                            <TextBlock Text="{Binding ActiveProfileName}"
                                       FontWeight="SemiBold" FontSize="12"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding ActiveControllerType, Converter={StaticResource ControllerTypeConverter}}"
                                       Style="{StaticResource TextLabel}" FontSize="10" Margin="0,2,0,0"
                                       Foreground="{StaticResource BrushHighlight}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ====== Right Content Area ====== -->
            <Grid Grid.Column="1">
                <!-- Page content switcher -->
                <Grid Margin="20">

                    <!-- Dashboard -->
                    <Grid Visibility="{Binding CurrentPage, Converter={StaticResource PageToDashboard}, ConverterParameter=Dashboard}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Dashboard" Style="{StaticResource TextHeading}" Margin="0,0,0,4"/>
                                <TextBlock Text="Monitor controller status and quick actions."
                                           Style="{StaticResource TextLabel}" Margin="0,0,0,20"/>

                                <!-- Quick stats cards -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Connection card -->
                                    <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="Connection" Style="{StaticResource TextLabel}"/>
                                            <TextBlock Margin="0,6,0,0" FontSize="20" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="●  OFF"/>
                                                        <Setter Property="Foreground" Value="#666680"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                                <Setter Property="Text" Value="●  ON"/>
                                                                <Setter Property="Foreground" Value="{StaticResource BrushSuccess}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Profile card -->
                                    <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="Profile" Style="{StaticResource TextLabel}"/>
                                            <TextBlock Text="{Binding ActiveProfileName}"
                                                       Margin="0,6,0,0" FontSize="16" FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Controller type card -->
                                    <Border Grid.Column="4" Style="{StaticResource CardBorder}">
                                        <StackPanel>
                                            <TextBlock Text="Controller" Style="{StaticResource TextLabel}"/>
                                            <TextBlock Text="{Binding ActiveControllerType, Converter={StaticResource ControllerTypeConverter}}"
                                                       Margin="0,6,0,0" FontSize="16" FontWeight="Bold"
                                                       Foreground="{StaticResource BrushHighlight}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- Status message -->
                                <Border Style="{StaticResource CardBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Status" Style="{StaticResource TextLabel}"/>
                                        <TextBlock Text="{Binding StatusMessage}"
                                                   Margin="0,6,0,0" FontSize="14"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Quick actions -->
                                <Border Style="{StaticResource CardBorder}">
                                    <StackPanel>
                                        <TextBlock Text="Quick Actions" Style="{StaticResource TextSubHeading}" Margin="0,0,0,12"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Button Content="▶  Connect" Command="{Binding ConnectCommand}"
                                                    Style="{StaticResource ButtonSuccess}" Margin="0,0,8,0"
                                                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisInvert}, ConverterParameter=Invert}"/>
                                            <Button Content="⏹  Disconnect" Command="{Binding DisconnectCommand}"
                                                    Style="{StaticResource ButtonDanger}" Margin="0,0,8,0"
                                                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="🎯  Open Mapping" Command="{Binding NavigateToMappingCommand}"
                                                    Margin="0,0,8,0"/>
                                            <Button Content="📁  Profiles" Command="{Binding NavigateToProfilesCommand}"/>
                                        </StackPanel>
                                        <TextBlock Style="{StaticResource TextLabel}"
                                                   Text="Default layout: WASD=Left Stick, Mouse=Right Stick, Space=A, LShift=B, E=X, Q=Y, LMB=RT, RMB=LT"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <!-- Embedded visualizer on dashboard -->
                                <views:ControllerVisualizerView x:Name="DashboardVisualizer"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Mapping Editor -->
                    <views:MappingEditorView
                        DataContext="{Binding MappingViewModel}"
                        Visibility="{Binding CurrentPage, Converter={StaticResource PageToMapping}, ConverterParameter=Mapping}"/>

                    <!-- Profile Manager -->
                    <views:ProfileManagerView
                        DataContext="{Binding ProfileViewModel}"
                        Visibility="{Binding CurrentPage, Converter={StaticResource PageToProfiles}, ConverterParameter=Profiles}"/>

                    <!-- Settings -->
                    <views:SettingsView
                        DataContext="{Binding}"
                        Visibility="{Binding CurrentPage, Converter={StaticResource PageToSettings}, ConverterParameter=Settings}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ==================== Status Bar ==================== -->
        <Border Grid.Row="2"
                Background="{StaticResource BrushSurface}"
                BorderBrush="{StaticResource BrushBorder}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Connection indicator -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Margin="0,0,5,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#666680"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource BrushSuccess}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock FontFamily="Segoe UI" FontSize="11" VerticalAlignment="Center"
                               Foreground="{StaticResource BrushTextSecondary}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Disconnected"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Text" Value="Connected"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Separator -->
                <Rectangle Grid.Column="1" Width="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>

                <!-- Active profile -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Profile: " Style="{StaticResource TextLabel}" FontSize="11"/>
                    <TextBlock Text="{Binding ActiveProfileName}"
                               Style="{StaticResource TextLabel}" FontSize="11"
                               FontWeight="SemiBold" Foreground="{StaticResource BrushTextPrimary}"/>
                </StackPanel>

                <Rectangle Grid.Column="3" Width="1" Fill="{StaticResource BrushBorder}" Margin="0,4"/>

                <!-- Status message -->
                <TextBlock Grid.Column="4"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource TextLabel}" FontSize="11"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <!-- Controller type -->
                <TextBlock Grid.Column="5"
                           Text="{Binding ActiveControllerType, Converter={StaticResource ControllerTypeConverter}}"
                           Style="{StaticResource TextLabel}" FontSize="11"
                           Foreground="{StaticResource BrushHighlight}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
